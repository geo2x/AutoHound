{
  "name": "autohound-installer",
  "version": "1.0.3",
  "description": "AutoHound Installer",
  "author": "ACH Research Division",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "io.ach.autohound",
    "productName": "AutoHound Setup",
    "win": {
      "target": "nsis",
      "icon": "assets/autohound.ico",
      "artifactName": "AutoHound_Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/autohound.ico",
      "installerHeaderIcon": "assets/autohound.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutoHound Setup",
      "artifactName": "AutoHound_Setup.exe",
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": ["**/*", "!installer/**", "!dist/**", "!venv/**", "!node_modules/**", "!.git/**", "!*.egg-info/**", "!__pycache__/**", "!test_output/**", "!docs/**", "!examples/**"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "three": "^0.183.2"
  }
}
