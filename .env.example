# BloodHound AI - Environment Configuration
# Copy this file to .env and fill in your API keys

# Anthropic Claude API Key (required for LLM reasoning)
ANTHROPIC_API_KEY=your_api_key_here

# Neo4j Connection (optional - only if using Neo4j instead of JSON export)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# LLM Configuration
CLAUDE_MODEL=claude-sonnet-4-6-20250514
MAX_TOKENS=4096
TEMPERATURE=0.0

# Logging
LOG_LEVEL=INFO
